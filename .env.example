# FoodLink Environment Variables
# Copy to .env and fill in values

# ─── Hedera ───────────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ACCOUNT_ID=0.0.XXXXXX
HEDERA_OPERATOR_PRIVATE_KEY=302e...
HEDERA_TOKEN_ID=0.0.XXXXXX
HEDERA_RECALL_TOPIC_ID=0.0.XXXXXX
HEDERA_CONTRACT_ID=0.0.XXXXXX
HEDERA_RECALL_MANAGER_CONTRACT_ID=0.0.XXXXXX

# ─── Hedera Guardian ──────────────────────────────────────────────────────────
GUARDIAN_API_URL=https://guardian.hedera.com
GUARDIAN_API_KEY=

# ─── OpenClaw ─────────────────────────────────────────────────────────────────
OPENCLAW_API_KEY=

# ─── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/foodlink

# ─── IPFS (Pinata) ────────────────────────────────────────────────────────────
PINATA_API_KEY=
PINATA_SECRET=

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
JWT_SECRET=change-me-in-production-use-32-char-minimum
DEMO_MODE=true

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
